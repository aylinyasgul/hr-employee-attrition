# Employee Attrition Prediction — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to Git — it is listed in .gitignore

# MLflow tracking server URI (used in stages 03, 04, 05)
MLFLOW_TRACKING_URI=http://127.0.0.1:5001

# Path to processed data (train.csv, test.csv, feature_columns.txt)
DATA_DIR=../data/processed

# Path to trained model artifacts (used in stage 06)
MODEL_DIR=models

# API port
PORT=9696
